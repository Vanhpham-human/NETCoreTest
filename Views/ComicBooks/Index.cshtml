@model IEnumerable<ComicSystem.Models.ComicBook>
@{
    ViewData["Title"] = "Quản lý truyện tranh";
}

<h2>Quản lý truyện tranh</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm truyện mới</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên truyện</th>
            <th>Tác giả</th>
            <th>Giá thuê/ngày</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>@item.PricePerDay.ToString("N0")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ComicBookID" class="btn btn-sm btn-warning">Sửa</a>
                <a asp-action="Delete" asp-route-id="@item.ComicBookID" class="btn btn-sm btn-danger">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>
